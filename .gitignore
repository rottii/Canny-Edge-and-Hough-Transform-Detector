# ==========================================
# Visual Studio .gitignore
# ==========================================

# Visual Studio cache/options directory
.vs/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results and directories
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Compiled Dynamic libraries
*.dll
*.so
*.dylib

# Compiled Executables and artifacts
*.exe
*.out
*.app
*.ilk
*.pdb
*.obj
*.idb
*.lib

# NuGet Packages
*.nupkg
packages/
!packages/build/

# IDE specific files
.idea/
*.vscode/